{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{# Title will be either 'New FAQ' or 'Edit FAQ' passed from controller #}
{% set selectedSubnavItem = 'faq' %}
{% set fullPageForm = true %}

{% block content %}
    <input type="hidden" name="action" value="craft-chat/faq/save">
    {{ redirectInput('craft-chat/faq') }}
    
    {% if faq.id %}
        <input type="hidden" name="faqId" value="{{ faq.id }}">
    {% endif %}

    {{ forms.textareaField({
        first: true,
        label: "Question"|t('craft-chat'),
        instructions: "The specific question asked by a user."|t('craft-chat'),
        id: 'question',
        name: 'question',
        value: faq.question,
        errors: faq.getErrors('question'),
        required: true,
        rows: 2
    }) }}

    {% set linkedEntryElements = [] %}
    {% if faq.linkedEntryId %}
        {% set linkedEntryElements = craft.entries.id(faq.linkedEntryId).all() %}
    {% endif %}

    {{ forms.elementSelectField({
        label: "Linked Entry (Optional)"|t('craft-chat'),
        instructions: "Link this FAQ to a specific entry (like a service or about page). If selected, the bot will pull its answer directly from this entry's content whenever this question is asked. This overrides any manual answer provided below."|t('craft-chat'),
        id: 'linkedEntryId',
        name: 'linkedEntryId',
        elementType: 'craft\\elements\\Entry',
        elements: linkedEntryElements,
        limit: 1
    }) }}

    <hr style="margin: 20px 0;">

    {{ forms.textareaField({
        label: "Manual Answer"|t('craft-chat'),
        instructions: "Provide the official answer here. If a Linked Entry is provided above, this manual answer will be ignored."|t('craft-chat'),
        id: 'answer',
        name: 'answer',
        value: faq.answer,
        errors: faq.getErrors('answer'),
        rows: 6
    }) }}

    {{ forms.textField({
        label: "Relevancy Counter"|t('craft-chat'),
        instructions: "Number of times this question or a similar one has been asked by visitors. Higher numbers indicate a missing piece of highly requested information."|t('craft-chat'),
        id: 'relevancyCounter',
        name: 'relevancyCounter',
        type: 'number',
        value: faq.relevancyCounter ?? 1,
        errors: faq.getErrors('relevancyCounter'),
        required: true
    }) }}
{% endblock %}
