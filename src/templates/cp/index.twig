{% extends "_layouts/cp" %}

{% set title = "Conversations"|t('craft-chat') %}

{% block content %}
    {% if conversations|length %}
        <div class="tableview" dir="ltr">
            <table class="data fullwidth">
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Date</th>
                        <th scope="col">Messages</th>
                        <th scope="col">Summary</th>
                        <th scope="col">Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for conversation in conversations %}
                        <tr>
                            <td><a href="{{ cpUrl('craft-chat/conversations/' ~ conversation.id) }}">{{ conversation.id }}</a></td>
                            <td>{{ conversation.dateUpdated|datetime('short') }}</td>
                            <td>{{ conversation.messageCount }}</td>
                            <td>{{ conversation.summary ? conversation.summary : 'No summary yet' }}</td>
                            <td>{{ conversation.status }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p>No conversations found.</p>
    {% endif %}
{% endblock %}
